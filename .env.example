# =============================================================================
# TRENDING NEWS PLATFORM — Environment Variables
# Generated from docs/.env.template (RTF source)
# =============================================================================
# NEVER commit this file to git. Add .env to .gitignore immediately.
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# -----------------------------------------------------------------------------
# SUPABASE
# Service key — bypasses RLS. Used by Inngest pipeline and setup scripts only.
# Anon key  — respects RLS. Used by Next.js / Expo frontends.
# Access token — your personal Supabase PAT for the Management API.
#   Get it at: https://supabase.com/dashboard/account/tokens
# -----------------------------------------------------------------------------
SUPABASE_URL=https://tzkdsiqqbkpqxwvatlaw.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_JWT_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_JWT_KEY
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_ACCESS_TOKEN

# Aliases used by Next.js (public, safe to expose in browser bundles)
NEXT_PUBLIC_SUPABASE_URL=https://tzkdsiqqbkpqxwvatlaw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_JWT_KEY

# -----------------------------------------------------------------------------
# SIGNAL COLLECTION
# -----------------------------------------------------------------------------
APIFY_API_KEY=YOUR_APIFY_API_KEY
NEWSAPI_KEY=YOUR_NEWSAPI_KEY
YOUTUBE_API_KEY=YOUR_GOOGLE_API_KEY

# -----------------------------------------------------------------------------
# AI / ML
# -----------------------------------------------------------------------------
GROQ_API_KEY=YOUR_GROQ_API_KEY
REPLICATE_API_KEY=YOUR_REPLICATE_API_KEY

# -----------------------------------------------------------------------------
# MEDIA GENERATION
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY

# -----------------------------------------------------------------------------
# DISTRIBUTION / NOTIFICATIONS
# -----------------------------------------------------------------------------
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
ONESIGNAL_API_KEY=YOUR_ONESIGNAL_API_KEY

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
RESEND_API_KEY=YOUR_RESEND_API_KEY

# -----------------------------------------------------------------------------
# ANALYTICS (Web app — must have NEXT_PUBLIC_ prefix for browser)
# Set in apps/web/.env.local or in your host (e.g. Vercel) for GA4 to track.
# -----------------------------------------------------------------------------
GA4_MEASUREMENT_ID=G-NBMQ66M04S
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-NBMQ66M04S

# -----------------------------------------------------------------------------
# PUBLICATION IDENTITY
# Used by setup scripts for CORS origins, redirect URLs, and site_url.
# -----------------------------------------------------------------------------
PUBLICATION_NAME=theNewslane
PUBLICATION_DOMAIN=thenewslane.com
AUTHOR_NAME=Aadi

# -----------------------------------------------------------------------------
# WEBHOOK SECURITY
# A secret appended to webhook requests so /api/webhooks/* can verify origin.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
