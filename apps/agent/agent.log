2026-02-24T14:39:41 [DEBUG   ] agent.nodes.content_generation_node: Raw response: {
  "seo_title": "WSJ Reporter Evan Gershkovich Appeals Arrest in Russia",
  "meta_description": "Evan Gershkovich, a Wall Street Journal reporter, appeals his arrest in Russia as the case gains global attention.",
  "summary_30w": "Wall Street Journal reporter Evan Gershkovich appeals his arrest in Russia, as the case draws international scrutiny and concerns over press freedom.",
  "article": "In a dramatic turn of events, Wall Street Journal reporter Evan Gershkovich has appealed against his arrest in Russia, according to Russian state media. Gershkovich, a US citizen, was detained in March 2023 on espionage charges, which the WSJ and US government have vehemently denied.

