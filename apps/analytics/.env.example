# ── Required ──────────────────────────────────────────────────────────────────
# Async connection string for FastAPI (uses asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# Sync connection string for training scripts (derived automatically if absent)
# DATABASE_URL_SYNC=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── Feature pipeline ─────────────────────────────────────────────────────────
FEATURE_PIPELINE_INTERVAL_MINUTES=15
